<Window x:Class="SimplePOS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ingreso al Sistema" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#f8fafc" FontFamily="Segoe UI">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,20,0,40" HorizontalAlignment="Center">
            <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="INICIAR SESIÓN" FontSize="24" FontWeight="Bold" Foreground="#1e293b" HorizontalAlignment="Center"/>
            <TextBlock Text="Ingresa tus credenciales para continuar" FontSize="14" Foreground="#64748b" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="USUARIO" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameBox" FontSize="18" Padding="10" Background="White" BorderBrush="#cbd5e1" BorderThickness="1" Margin="0,0,0,20">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <TextBlock Text="CONTRASEÑA" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" FontSize="18" Padding="10" Background="White" BorderBrush="#cbd5e1" BorderThickness="1">
                <PasswordBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </PasswordBox.Resources>
            </PasswordBox>

            <TextBlock x:Name="ErrorText" Foreground="#dc2626" FontWeight="SemiBold" Margin="0,15,0,0" Visibility="Collapsed" TextAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="2" Content="INGRESAR" Click="LoginButton_Click" IsDefault="True" Height="50" Margin="0,20,0,0" 
                Background="#2563eb" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
